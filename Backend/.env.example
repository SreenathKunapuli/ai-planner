# Copy to .env and fill in from your dashboards. Never commit .env.

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Supabase — Dashboard > Settings > API
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=

# Supabase Dashboard > Settings > API > JWT Secret (legacy HS256 projects).
# Leave empty on newer projects — the API falls back to JWKS verification.
SUPABASE_JWT_SECRET=

# Comma-separated origins allowed to call the API cross-origin (dev frontend).
# In production the frontend is served same-origin, so this can stay as-is.
CORS_ORIGINS=http://localhost:5173
